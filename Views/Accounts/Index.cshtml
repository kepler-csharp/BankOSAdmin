@model List<BankAdmin.Models.AccountModel>
@{
    ViewBag.Title = "Cuentas";
    string StatusBadge(AccountModel a) => a.Status switch
    {
        "active" => "<span class=\"badge badge-active\">Activa</span>",
        "blocked" => "<span class=\"badge badge-inactive\">Bloqueada</span>",
        _ => "<span class=\"badge badge-inactive\">Inactiva</span>"
    };
}

<main class="main">
    <div class="page-header">
        <div>
            <div class="eyebrow">@ViewBag.TenantName</div>
            <h1 class="page-title">Cuentas bancarias</h1>
            <p class="page-subtitle">@Model.Count cuenta@(Model.Count == 1 ? "" : "s") · @Model.Count(a => a.IsActive) activa@(Model.Count(a => a.IsActive) == 1 ? "" : "s").</p>
        </div>
        <a class="btn btn-brand" href="@Url.Action("Create")"><i class="fa-solid fa-plus"></i> Nueva cuenta</a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success"><i class="fa-solid fa-circle-check"></i><span>@TempData["Success"]</span></div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-error"><i class="fa-solid fa-circle-exclamation"></i><span>@TempData["Error"]</span></div>
    }

    <div class="card">
        <div class="card-body" style="padding:0;">
            @if (Model.Count == 0)
            {
                <div class="empty"><div class="empty-title">Sin cuentas</div><div class="empty-text">Crea la primera cuenta y asígnala a un cliente.</div></div>
            }
            else
            {
                <div class="table-wrap" style="border:none;">
                    <table class="data">
                        <thead><tr><th>Número de cuenta</th><th>Titular</th><th>Saldo</th><th>Moneda</th><th>Estado</th><th style="text-align:right;">Acciones</th></tr></thead>
                        <tbody>
                        @foreach (var a in Model)
                        {
                            <tr>
                                <td style="font-family:var(--mono);font-size:12.5px;color:var(--ink);">@a.AccountNumber</td>
                                <td>@(a.OwnerName ?? "—")<br /><span style="color:var(--s-400);font-size:11.5px;">@a.OwnerEmail</span></td>
                                <td style="font-weight:700;color:var(--ink);">@a.Balance.ToString("N2")</td>
                                <td>@a.Currency</td>
                                <td>@Html.Raw(StatusBadge(a))</td>
                                <td>
                                    <div style="display:flex;gap:6px;justify-content:flex-end;">
                                        <a class="btn btn-secondary btn-sm" href="@Url.Action("Edit", new { id = a.Id })" title="Editar cuenta"><i class="fa-solid fa-pen"></i></a>
                                        <a class="btn btn-secondary btn-sm" href="@Url.Action("Certificate", new { id = a.Id })" title="Certificado PDF"><i class="fa-solid fa-file-arrow-down"></i></a>
                                        @if (a.IsActive)
                                        {
                                            <button type="button" class="btn btn-warning btn-sm" title="Desactivar cuenta"
                                                    onclick="openConfirm(this)"
                                                    data-action="@Url.Action("ToggleStatus")" data-id="@a.Id"
                                                    data-icon="warn" data-confirm-label="Desactivar cuenta" data-confirm-class="btn-warning" data-show-reason="1"
                                                    data-title="Desactivar cuenta @a.AccountNumber"
                                                    data-message="La cuenta dejará de operar y no podrá realizar transacciones. Se notificará al titular por correo."
                                                    data-money="@(a.Balance > 0 ? $"Esta cuenta tiene un saldo de {a.Balance:N2} {a.Currency}. Los fondos se conservan." : "")">
                                                <i class="fa-solid fa-ban"></i>
                                            </button>
                                        }
                                        else
                                        {
                                            <button type="button" class="btn btn-success btn-sm" title="Reactivar cuenta"
                                                    onclick="openConfirm(this)"
                                                    data-action="@Url.Action("ToggleStatus")" data-id="@a.Id"
                                                    data-icon="ok" data-confirm-label="Reactivar cuenta" data-confirm-class="btn-success"
                                                    data-title="Reactivar cuenta @a.AccountNumber"
                                                    data-message="La cuenta volverá a estar operativa. Se notificará al titular por correo.">
                                                <i class="fa-solid fa-play"></i>
                                            </button>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</main>

@await Html.PartialAsync("_ConfirmModal")
