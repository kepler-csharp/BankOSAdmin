@model BankAdmin.Models.TransferViewModel
@{
    ViewBag.Title = "Realizar transferencia";
    var accounts = ViewBag.Accounts as List<AccountModel> ?? new List<AccountModel>();
}

<main class="main" style="max-width:680px;">
    <div class="page-header">
        <div>
            <div class="eyebrow"><a href="@Url.Action("Index")" style="color:var(--s-400);text-decoration:none;">Transacciones</a> · Transferencia</div>
            <h1 class="page-title">Realizar transferencia</h1>
            <p class="page-subtitle">Mueve fondos entre cuentas del banco.</p>
        </div>
    </div>

    @if (ViewBag.Error != null)
    {
        <div class="alert alert-error"><i class="fa-solid fa-circle-exclamation"></i><span>@ViewBag.Error</span></div>
    }

    <form method="post" action="@Url.Action("Transfer")" id="tr-form">
        @Html.AntiForgeryToken()
        <div class="card">
            <div class="card-body">
                <div class="form-group">
                    <label class="form-label" asp-for="SourceAccountId">Cuenta origen</label>
                    <select class="form-input" asp-for="SourceAccountId" id="tr-source" required>
                        <option value="">— Selecciona la cuenta origen —</option>
                        @foreach (var a in accounts)
                        {
                            <option value="@a.Id" data-currency="@a.Currency">@a.AccountNumber — @(a.OwnerName ?? "titular") · saldo @a.Balance.ToString("N2") @a.Currency</option>
                        }
                    </select>
                </div>
                <div class="form-group">
                    <label class="form-label" asp-for="DestinationAccountId">Cuenta destino</label>
                    <select class="form-input" asp-for="DestinationAccountId" id="tr-dest" required>
                        <option value="">— Selecciona la cuenta destino —</option>
                        @foreach (var a in accounts)
                        {
                            <option value="@a.Id">@a.AccountNumber — @(a.OwnerName ?? "titular") (@a.Currency)</option>
                        }
                    </select>
                </div>
                <div class="grid-2">
                    <div class="form-group">
                        <label class="form-label" asp-for="Amount">Monto</label>
                        <input class="form-input" type="number" step="0.01" min="0.01" asp-for="Amount" id="tr-amount" placeholder="0.00" required />
                    </div>
                    <div class="form-group">
                        <label class="form-label" asp-for="Currency">Moneda</label>
                        <select class="form-input" asp-for="Currency" id="tr-currency">
                            <option value="COP">COP</option>
                            <option value="USD">USD</option>
                            <option value="EUR">EUR</option>
                        </select>
                    </div>
                </div>
                <div class="form-group" style="margin-bottom:0;">
                    <label class="form-label" asp-for="Description">Descripción (opcional)</label>
                    <input class="form-input" asp-for="Description" placeholder="Ej. transferencia entre cuentas" />
                </div>
            </div>
        </div>
        <div style="display:flex;gap:10px;justify-content:flex-end;margin-top:18px;">
            <a class="btn btn-secondary" href="@Url.Action("Index")">Cancelar</a>
            <button type="button" class="btn btn-brand btn-lg" onclick="confirmTransfer()"><i class="fa-solid fa-right-left"></i> Transferir</button>
        </div>
    </form>
</main>

<div class="modal-overlay" id="trModal" onclick="if(event.target===this)closeTr()">
    <div class="modal" role="dialog" aria-modal="true">
        <div class="modal-head">
            <div class="modal-icon warn"><i class="fa-solid fa-right-left"></i></div>
            <h3>Confirmar transferencia</h3>
        </div>
        <div class="modal-body">
            Vas a transferir <b id="tr-confirm-amount"></b>.
            <div class="modal-detail">
                <div class="r"><span class="k">Origen</span><span class="v" id="tr-confirm-src" style="font-family:var(--mono);font-size:12px;"></span></div>
                <div class="r"><span class="k">Destino</span><span class="v" id="tr-confirm-dst" style="font-family:var(--mono);font-size:12px;"></span></div>
            </div>
            <div class="modal-money"><i class="fa-solid fa-triangle-exclamation"></i><span>Mover fondos es una operación sensible e irreversible. Verifica las cuentas antes de continuar.</span></div>
        </div>
        <div class="modal-foot">
            <button type="button" class="btn btn-secondary" onclick="closeTr()">Cancelar</button>
            <button type="button" class="btn btn-brand" onclick="document.getElementById('tr-form').submit()">Sí, transferir</button>
        </div>
    </div>
</div>

@section Scripts {
<script>
    function confirmTransfer() {
        var src = document.getElementById('tr-source');
        var dst = document.getElementById('tr-dest');
        var amount = document.getElementById('tr-amount').value;
        var cur = document.getElementById('tr-currency').value;
        if (!src.value || !dst.value || !amount || parseFloat(amount) <= 0 || src.value === dst.value) {
            document.getElementById('tr-form').submit(); return;
        }
        document.getElementById('tr-confirm-amount').textContent = parseFloat(amount).toLocaleString('es-CO', { minimumFractionDigits: 2 }) + ' ' + cur;
        document.getElementById('tr-confirm-src').textContent = src.options[src.selectedIndex].text;
        document.getElementById('tr-confirm-dst').textContent = dst.options[dst.selectedIndex].text;
        document.getElementById('trModal').classList.add('open');
    }
    function closeTr() { document.getElementById('trModal').classList.remove('open'); }
    document.getElementById('tr-source').addEventListener('change', function () {
        var c = this.options[this.selectedIndex].dataset.currency;
        if (c) document.getElementById('tr-currency').value = c;
    });
    document.addEventListener('keydown', function (e) { if (e.key === 'Escape') closeTr(); });
</script>
}
